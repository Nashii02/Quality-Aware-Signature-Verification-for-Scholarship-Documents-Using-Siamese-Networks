BEGIN Process_1_0_Data_Preprocessing
    INPUT Satellite_Bands_GeoTIFF (B3, B4, B8, B11), AOI_Shapefile, Historical_Labels

    // Validate inputs and cloud cover
    IF AOI_Shapefile IS MISSING THEN
        OUTPUT ERROR "Missing required AOI Shapefile."
        TERMINATE Process
    ENDIF

    IF Cloud_Cover_Percentage > 10 THEN
        OUTPUT ERROR "Cloud cover exceeds 10% limit."
        TERMINATE Process
    ENDIF

    // Crop bands to study area and stack channels
    CROP Satellite_Bands TO AOI_Shapefile
    STACK B3, B4, B8, B11 INTO MultiSpectral_Matrix

    // Calculate NDVI channel
    FOR EACH Pixel IN MultiSpectral_Matrix DO
        COMPUTE NDVI = (Band_8 - Band_4) / (Band_8 + Band_4 + 0.0000000001)
        APPEND NDVI AS Channel_5 TO MultiSpectral_Matrix
    ENDFOR

    // Min-Max Normalization (scale to 0-1)
    FOR EACH Channel IN MultiSpectral_Matrix DO
        FIND Channel_Min AND Channel_Max
        FOR EACH Pixel IN Channel DO
            SET Normalized_Pixel = (Pixel - Channel_Min) / (Channel_Max - Channel_Min)
        ENDFOR
    ENDFOR

    // Generate 256x256 image patches with stride 128
    SET Patch_Size = 256
    SET Stride = 128

    FOR Row = 0 TO (Image_Height - Patch_Size) STEP Stride DO
        FOR Col = 0 TO (Image_Width - Patch_Size) STEP Stride DO
            EXTRACT Image_Patch FROM MultiSpectral_Matrix
            EXTRACT Label_Patch FROM Historical_Labels
            SAVE Image_Patch AND Label_Patch TO Data_Store_D2
        ENDFOR
    ENDFOR

    OUTPUT Preprocessed_Patches, Preprocessed_Full_Scenes
END Process_1_0_Data_Preprocessing
