BEGIN Process_3_0_Temporal_Change_Detection
    INPUT Binary_Mask_T1 FROM Data_Store_D4, Binary_Mask_T2 FROM Data_Store_D4

    // Verify raster dimensions match
    IF Binary_Mask_T1_Dimensions != Binary_Mask_T2_Dimensions THEN
        OUTPUT ERROR "Image dimensions between baseline and target year do not match."
        TERMINATE Process
    ENDIF

    CREATE Change_Matrix OF SAME SIZE AS Mask_T1
    SET Stable_Count = 0
    SET Loss_Count = 0
    SET Gain_Count = 0
    SET Unchanged_Count = 0

    // Compare pixels between Year 1 (T1) and Year 2 (T2)
    FOR EACH Pixel IN Image_Grid DO
        READ Value_T1 FROM Binary_Mask_T1
        READ Value_T2 FROM Binary_Mask_T2

        IF Value_T1 == 1 AND Value_T2 == 1 THEN
            SET Change_Matrix_Pixel = 1 // Stable Mangrove
            INCREMENT Stable_Count
        ELSE IF Value_T1 == 1 AND Value_T2 == 0 THEN
            SET Change_Matrix_Pixel = 2 // Mangrove Loss
            INCREMENT Loss_Count
        ELSE IF Value_T1 == 0 AND Value_T2 == 1 THEN
            SET Change_Matrix_Pixel = 3 // Mangrove Gain
            INCREMENT Gain_Count
        ELSE
            SET Change_Matrix_Pixel = 0 // Unchanged Non-Mangrove
            INCREMENT Unchanged_Count
        ENDIF
    ENDFOR

    // Convert pixel counts to hectares (1 pixel = 10m x 10m = 0.01 ha)
    SET Pixel_Area_Ha = 0.01
    CALCULATE Stable_Hectares = Stable_Count * Pixel_Area_Ha
    CALCULATE Loss_Hectares = Loss_Count * Pixel_Area_Ha
    CALCULATE Gain_Hectares = Gain_Count * Pixel_Area_Ha
    CALCULATE Net_Change_Hectares = Gain_Hectares - Loss_Hectares

    SAVE Change_Matrix TO Data_Store_D5
    SAVE Area_Stats_Table TO Data_Store_D5

    OUTPUT Change_Matrix, Area_Stats_Table
END Process_3_0_Temporal_Change_Detection
