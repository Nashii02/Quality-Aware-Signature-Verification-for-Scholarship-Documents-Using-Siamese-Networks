BEGIN Process_4_0_Web_Dashboard_And_Reporting
    INPUT Selected_Year_T1, Selected_Year_T2, Layer_Toggles, Data_Store_D5

    // Check year selection logic
    IF Selected_Year_T1 >= Selected_Year_T2 THEN
        DISPLAY WARNING "Selected baseline year must be earlier than evaluation year."
        PROMPT User TO ReSelect_Years
        TERMINATE Subroutine
    ENDIF

    // Fetch and display change data
    FETCH Change_Matrix FROM Data_Store_D5 FOR (Selected_Year_T1, Selected_Year_T2)
    FETCH Area_Stats_Table FROM Data_Store_D5 FOR (Selected_Year_T1, Selected_Year_T2)

    DISPLAY Map_View (Base_Map, Change_Matrix, Layer_Toggles)
    DISPLAY Stats_Panel (Gain_Hectares, Loss_Hectares, Net_Change_Hectares)

    // User action handler
    WHILE User_Session_Is_Active DO
        IF User_Clicks_Export_PDF THEN
            CAPTURE Current_Map_Screenshot
            GENERATE PDF_Report (Current_Map_Screenshot, Area_Stats_Table, System_Date)
            DOWNLOAD PDF_Report
        ENDIF
    ENDWHILE

    OUTPUT Interactive_Map_View, PDF_Report
END Process_4_0_Web_Dashboard_And_Reporting
