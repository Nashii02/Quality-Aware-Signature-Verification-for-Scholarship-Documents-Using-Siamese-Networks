BEGIN Process_2_0_UNet_Segmentation_Engine
    INPUT Preprocessed_Patches FROM Data_Store_D2, Unlabeled_Annual_Scenes FROM Data_Store_D2

    IF Preprocessed_Patches IS EMPTY THEN
        OUTPUT ERROR "No preprocessed training patches found."
        TERMINATE Process
    ENDIF

    // Initialize U-Net architecture
    BUILD UNet_Model (4 Encoder Layers, Bottleneck, 4 Decoder Layers with Skip Connections)
    SET Batch_Size = 32
    SET Epochs = 50
    SET Best_Val_Loss = 999999.0

    // Model training loop
    FOR Epoch = 1 TO Epochs DO
        FOR EACH Batch IN Preprocessed_Patches DO
            PASS Batch THROUGH UNet_Model TO GET Predicted_Masks
            CALCULATE Loss USING Binary_Cross_Entropy
            UPDATE Model_Weights USING ADAM_Optimizer
        ENDFOR

        EVALUATE UNet_Model ON Validation_Set
        CALCULATE Current_Val_Loss

        IF Current_Val_Loss < Best_Val_Loss THEN
            SET Best_Val_Loss = Current_Val_Loss
            SAVE Model_Weights TO Data_Store_D3 ("best_mangrove_model.h5")
        ENDIF
    ENDFOR

    // Full-scene inference for target years
    LOAD Model_Weights FROM Data_Store_D3 ("best_mangrove_model.h5")

    FOR EACH Target_Year IN [2019, 2021, 2023, 2024] DO
        FETCH Full_Scene FROM Data_Store_D2 FOR Target_Year
        CREATE Empty_Probability_Map OF SAME SIZE AS Full_Scene

        // Predict on full scene using sliding window
        FOR EACH Patch IN Full_Scene USING Sliding_Window(256x256, Stride=256) DO
            PREDICT Patch_Probabilities USING UNet_Model
            PASTE Patch_Probabilities INTO Empty_Probability_Map
        ENDFOR

        // Apply 0.5 threshold to build binary mask
        CREATE Binary_Mask OF SAME SIZE AS Full_Scene
        FOR EACH Pixel IN Empty_Probability_Map DO
            IF Pixel_Value >= 0.5 THEN
                SET Binary_Mask_Pixel = 1
            ELSE
                SET Binary_Mask_Pixel = 0
            ENDIF
        ENDFOR

        SAVE Binary_Mask TO Data_Store_D4 FOR Target_Year
    ENDFOR

    OUTPUT Annual_Binary_Mangrove_Masks
END Process_2_0_UNet_Segmentation_Engine
