FUNCTION TrainAndPredictUNet(DataStore_D2)
BEGIN
    Patches = ReadDataStore("D2_Patches")
    IF Length(Patches) == 0 THEN
        RAISE Exception("Data store D2 contains no patches.")
        RETURN FALSE
    END IF

    Model = CreateUNetModel(InputChannels=5)
    BatchSize = 32
    Epochs = 50
    BestLoss = 999999.0

    FOR Epoch FROM 1 TO Epochs DO
        FOR EACH Batch IN GetBatches(Patches, BatchSize) DO
            Predictions = Model.Forward(Batch.Images)
            Loss = BinaryCrossEntropy(Predictions, Batch.Labels)
            Model.BackwardAndUpdate(Loss, Optimizer="ADAM")
        END FOR

        ValLoss = Model.Evaluate(DataStore_D2.ValidationPatches)
        IF ValLoss < BestLoss THEN
            BestLoss = ValLoss
            SaveWeights(Model, "D3_Weights/best_mangrove_model.h5")
        END IF
    END FOR

    LoadedModel = LoadWeights("D3_Weights/best_mangrove_model.h5")
    YearsList = [2019, 2021, 2023, 2024]

    FOR EACH Year IN YearsList DO
        FullScene = ReadDataStore("D2_FullScenes", Year)
        ProbMap = CreateEmptyRaster(FullScene.Dimensions)

        FOR EACH (Patch, Row, Col) IN GetSlidingWindows(FullScene, Size=256, Stride=256) DO
            PatchPred = LoadedModel.Predict(Patch)
            ProbMap.Insert(PatchPred, Row, Col)
        END FOR

        BinaryMask = CreateEmptyRaster(FullScene.Dimensions)
        FOR Row FROM 0 TO ProbMap.Height - 1 DO
            FOR Col FROM 0 TO ProbMap.Width - 1 DO
                IF ProbMap[Row, Col] >= 0.5 THEN
                    BinaryMask[Row, Col] = 1
                ELSE
                    BinaryMask[Row, Col] = 0
                END IF
            END FOR
        END FOR

        WriteDataStore("D4_BinaryMasks", BinaryMask, Year)
    END FOR

    RETURN TRUE
END
