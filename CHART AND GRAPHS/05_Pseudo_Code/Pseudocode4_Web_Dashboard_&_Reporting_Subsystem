FUNCTION RunDashboardSubsystem(Year_T1, Year_T2, VisibleLayers)
BEGIN
    IF Year_T1 >= Year_T2 THEN
        ShowUserAlert("Baseline year must be earlier than target year.")
        RETURN FALSE
    END IF

    ChangeMap = ReadDataStore("D5_ChangeMaps", Year_T1, Year_T2)
    StatsData = ReadDataStore("D5_Stats", Year_T1, Year_T2)

    RenderMap(ChangeMap, VisibleLayers)
    RenderStatsTable(StatsData)

    WHILE CheckSessionActive() DO
        Event = GetNextUIEvent()
        IF Event.Type == "EXPORT_PDF_CLICKED" THEN
            Screenshot = CaptureCanvas()
            PDFFile = GeneratePDFReport(Screenshot, StatsData, GetCurrentDate())
            DownloadToUser(PDFFile)
        END IF
    END WHILE

    RETURN TRUE
END
