FUNCTION DetectTemporalChange(Mask_T1, Mask_T2)
BEGIN
    IF Mask_T1.Width != Mask_T2.Width OR Mask_T1.Height != Mask_T2.Height THEN
        RAISE Exception("Mask dimensions do not match.")
        RETURN NULL
    END IF

    ChangeMatrix = CreateEmptyRaster(Mask_T1.Dimensions)
    StableCount = 0
    LossCount = 0
    GainCount = 0
    UnchangedCount = 0

    FOR Row FROM 0 TO Mask_T1.Height - 1 DO
        FOR Col FROM 0 TO Mask_T1.Width - 1 DO
            Pixel_T1 = Mask_T1[Row, Col]
            Pixel_T2 = Mask_T2[Row, Col]

            IF Pixel_T1 == 1 AND Pixel_T2 == 1 THEN
                ChangeMatrix[Row, Col] = 1
                StableCount = StableCount + 1
            ELSE IF Pixel_T1 == 1 AND Pixel_T2 == 0 THEN
                ChangeMatrix[Row, Col] = 2
                LossCount = LossCount + 1
            ELSE IF Pixel_T1 == 0 AND Pixel_T2 == 1 THEN
                ChangeMatrix[Row, Col] = 3
                GainCount = GainCount + 1
            ELSE
                ChangeMatrix[Row, Col] = 0
                UnchangedCount = UnchangedCount + 1
            END IF
        END FOR
    END FOR

    HectareFactor = 0.01
    StableHa = StableCount * HectareFactor
    LossHa = LossCount * HectareFactor
    GainHa = GainCount * HectareFactor
    NetHa = GainHa - LossHa

    StatsSummary = FormatStats(StableHa, LossHa, GainHa, NetHa)

    WriteDataStore("D5_ChangeMaps", ChangeMatrix)
    WriteDataStore("D5_Stats", StatsSummary)

    RETURN ChangeMatrix, StatsSummary
END
