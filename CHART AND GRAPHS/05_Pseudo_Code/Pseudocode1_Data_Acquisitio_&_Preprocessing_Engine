FUNCTION PreprocessData(SatelliteBands, AOIShapefile, GroundTruthLabels)
BEGIN
    IF AOIShapefile IS NULL THEN
        RAISE Exception("AOI shapefile is missing.")
        RETURN FALSE
    END IF

    IF SatelliteBands.CloudCover > 10 THEN
        RAISE Exception("Cloud cover exceeds threshold.")
        RETURN FALSE
    END IF

    ClippedBands = CropToBoundary(SatelliteBands, AOIShapefile)
    StackedMatrix = StackBands(ClippedBands.B3, ClippedBands.B4, ClippedBands.B8, ClippedBands.B11)

    // Append NDVI
    NDVI = (StackedMatrix.B8 - StackedMatrix.B4) / (StackedMatrix.B8 + StackedMatrix.B4 + 1e-10)
    StackedMatrix.AddChannel(NDVI)

    // Normalize channels
    FOR EACH Channel IN StackedMatrix.Channels DO
        MinVal = GetMinimum(Channel)
        MaxVal = GetMaximum(Channel)
        Channel = (Channel - MinVal) / (MaxVal - MinVal)
    END FOR

    PatchSize = 256
    Stride = 128

    FOR Row FROM 0 TO (StackedMatrix.Height - PatchSize) STEP Stride DO
        FOR Col FROM 0 TO (StackedMatrix.Width - PatchSize) STEP Stride DO
            ImagePatch = GetCrop(StackedMatrix, Row, Col, PatchSize)
            LabelPatch = GetCrop(GroundTruthLabels, Row, Col, PatchSize)
            SaveToDataStore("D2_Patches", ImagePatch, LabelPatch)
        END FOR
    END FOR

    RETURN TRUE
END
